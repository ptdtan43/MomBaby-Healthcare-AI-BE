# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/healthsync?retryWrites=true&w=majority

# Server
PORT=5000
JWT_SECRET=replace_with_a_secure_random_string

# Firebase
# Put your Firebase service account JSON file in the backend folder
FIREBASE_ADMIN_KEY_PATH=./firebase-service-account.json

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_SECURE=false

# Twilio (SMS)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# AI / External APIs
BIOMISTRAL_API_KEY=
HF_API_KEY=
